{
  // ╔══════════════════════════════════════════════════════════════════╗
  // ║                   🎨 MrDib's VS CODE MASTERPIECE                 ║
  // ║              ⚡ Professional AI-Enhanced Edition v4.0 ⚡         ║
  // ║        "Where Code Meets Art, Productivity & Intelligence" 🚀    ║
  // ╚══════════════════════════════════════════════════════════════════╝

  // ┌─────────────────────────────────────────────────────────────────┐
  // │             🪟 WINDOW & INTERFACE MAGNIFICENCE                  │
  // │         Making your IDE look like it came from 2050             │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🎭 Window Appearance - Because first impressions matter!
  "window.customTitleBarVisibility": "windowed",
  "window.title": "MrDib ${activeEditorMedium} ${rootPath}",
  "window.newWindowDimensions": "inherit",
  "window.nativeFullScreen": true,
  "window.zoomLevel": 1.4,
  "editor.fontSize": 13,

  //? 💎 Transparency & Visual Effects - That sexy glass effect!
  //! May cause productivity boost due to sheer awesomeness 🥃
  "apc.electron": {
    "opacity": 0.98,
    "transparent": true,
    "backgroundColor": "#00000000",
    "vibrancy": "ultra-dark"
  },

  // ┌─────────────────────────────────────────────────────────────────┐
  // │                 📁 FILE MANAGEMENT EXCELLENCE                   │
  // │            Because your files deserve VIP treatment             │
  // └─────────────────────────────────────────────────────────────────┘

  //? 💾 Auto-Save Magic - Ctrl+S is so 2010! Your fingers will thank you
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 2000,

  //? 🧹 File Cleanup Squad - Keeping your code pristine & professional
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,

  //? 🗂️ File Associations - Teaching VS Code what's what
  "files.associations": {
    "*.html": "html",
    ".php_cs": "php",
    ".php_cs.dist": "php"
  },

  //? 🗺️ Explorer Settings - Navigate like a pro!
  "files.enableTrash": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.autoReveal": true,

  //? 🙈 File Exclusions - Hide the mundane, show the extraordinary
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },

  //? 👁️ Watcher Exclusions - Don't watch what doesn't matter
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/dist/**": true,
    "**/.cache/**": true,
    "**/build/**": true,
    "**/.venv/**": true,
    "**/__pycache__/**": true
  },
  "editor.minimap.enabled": false,
  "editor.renderLineHighlight": "none",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.renderControlCharacters": false,
  "editor.colorDecorators": false,
  "editor.lightbulb.enabled": "off",
  "editor.stickyScroll.enabled": false,
  "editor.matchBrackets": "never",

  //? ✨ LEGENDARY CURSOR SETTINGS - The cursor that conquered a thousand bugs!
  //! Witness the glowing beacon of productivity! 🌟
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "apc.stylesheet": {
    ".monaco-editor .cursor": "background: #ffffff !important; box-shadow: 0 0 8px 1px #00ff00; width: 2px !important;"
  },

  //? 🏄 Smooth Scrolling - Butter smooth, like your code should be
  "editor.smoothScrolling": true,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.mouseWheelZoom": true,

  //? 📐 Indentation Perfection - Because spaces matter (literally!)
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": false,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,

  //? 🔦 Selection & Highlighting - Illuminate your code journey
  "editor.selectionHighlight": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.wordSeparators": "`~!@#%^&*()=+[{]}\\|;:'\",.<>/?",

  //? 🔤 Typography Excellence - Ligatures for the sophisticated developer
  "editor.fontLigatures": true,

  //? 🧠 IntelliSense & Suggestions - Your AI coding companion
  "editor.suggestLineHeight": 30,
  "editor.suggestFontSize": 20,
  "editor.snippetSuggestions": "inline",
  "editor.copyWithSyntaxHighlighting": false,

  //? 📝 Snippet settings - Because even snippets deserve formatting
  "[snippets]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  //? 🎈 Hover Settings - Patience is a virtue
  "editor.hover.delay": 1500,
  "editor.hover.enabled": "on",

  //? 🧭 Navigation Settings - Jump to definition like a ninja!
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",

  //? ♿ Accessibility - We code for everyone
  "editor.accessibilitySupport": "off",

  //? 🛠️ Update Imports on File Move - Unified JS/TS Management
  //? 📦 ES6 modules FTW!
  "js/ts.updateImportsOnFileMove.enabled": "always",

  // ┌─────────────────────────────────────────────────────────────────┐
  // │                  🎨 WORKBENCH & THEME ARTISTRY                  │
  // │              Where aesthetics meet functionality                │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🍬 Theme & Icons - Eye candy that doesn't cause cavities!
  "workbench.colorTheme": "Transparent Color Theme",
  "workbench.iconTheme": "material-icon-theme",

  //? 🎨 Custom Color Palette - Painted with love and precision
  "workbench.colorCustomizations": {
    "editorIndentGuide.background1": "#1E1E1E",
    "terminal.background": "#00000000",
    "editorLineNumber.foreground": "#858585",
    "editorLineNumber.activeForeground": "#00ff00"
  },

  //? 🏗️ Layout Architecture - Feng Shui for your workspace
  "workbench.sideBar.location": "right",
  "workbench.tree.indent": 10,
  "workbench.statusBar.visible": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": true,
  "workbench.list.smoothScrolling": true,

  //? 📑 Tab Management - Organizing tabs like a boss since 2024
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.labelFormat": "default",
  "workbench.editor.openPositioning": "last",
  "workbench.editor.closeEmptyGroups": true,
  "workbench.editor.showIcons": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.wrapTabs": false,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.tabActionCloseVisibility": false,
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 10,
  "workbench.layoutControl.enabled": false,

  // ┌─────────────────────────────────────────────────────────────────┐
  // │               🚀 ANIMATIONS & SPECIAL EFFECTS                   │
  // │        Because coding should feel like a video game!            │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🎮 VS Code Animations - Level up your coding experience!
  //! Side effects may include increased dopamine levels
  "animations.Enabled": true,
  "animations.CursorAnimation": true,
  "animations.Command-Palette": "Fade",
  "animations.Active": "Indent",
  "animations.Install-Method": "Apc Customize UI++",
  "animations.CursorAnimationOptions": {
    "TrailLength": 20
  },

  //? 🎪 Modern Custom UI - Replaces the broken Legacy Loader
  //? ⚠️ Update version number if VSCode Animations extension updates
  "apc.imports": [
    "file:///Users/dibakar/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.7/dist/updateHandler.js"
  ],
  "vscode_custom_css.imports": [
    "file:///Users/dibakar/Documents/Documents%20-%20DIBAKAR%E2%80%99s%20MacBook%20Pro/Code/CustomCode/CustomCSS.css",
    "file:///Users/dibakar/Documents/Documents%20-%20DIBAKAR%E2%80%99s%20MacBook%20Pro/Code/CustomCode/CustomJavascript.js"
  ],

  // ┌─────────────────────────────────────────────────────────────────┐
  // │                💻 TERMINAL CONFIGURATION HQ                     │
  // │             Your command line, but make it fashion              │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🖥️ Terminal Aesthetics - Making terminal sessions sexy since forever
  "terminal.integrated.fontFamily": "Cascadia Code, MesloLGS NF",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.tabs.title": "${process} ~ MrDib",

  //? ⚡ Terminal Behavior - Smooth as silk, fast as lightning
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.smoothScrolling": true,
  "debug.terminal.clearBeforeReusing": true,
  "python.terminal.focusAfterLaunch": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.minimumContrastRatio": 4.5,
  "terminal.integrated.env.osx": {},
  "terminal.integrated.persistentSessionReviveProcess": "never",

  // ┌─────────────────────────────────────────────────────────────────┐
  // │              🔧 LANGUAGE FORMATTERS & COMPILERS                 │
  // │         Supporting more languages than the United Nations       │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🎯 Default Formatter - Prettier, because ugly code is a crime
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  //? 🌐 HTML Configuration - Making the web beautiful
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  //? 🐍 Python Configuration - Snake charming at its finest
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4,
    "editor.formatOnSave": true
  },
  "python.createEnvironment.trigger": "off",

  //? ☕ Java Configuration - Brewing perfect code since 1995
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.formatOnSave": true
  },
  "java.import.generatesMetadataFilesAtProjectRoot": true,

  //? 🔩 C Language Configuration - Old school cool
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },

  //? 🐚 Shell Script Configuration - Unix philosophy approved!
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },

  "[dockerfile]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },

  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },

  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },

  //? 🌊 Shell Format Languages - Format ALL the things!
  "shellformat.effectLanguages": [
    "shellscript",
    "dockerfile",
    "dotenv",
    "hosts",
    "jvmoptions",
    "ignore",
    "gitignore",
    "properties",
    "spring-boot-properties",
    "azcli",
    "bats"
  ],

  //? 📓 Notebook Configuration - Jupyter never looked so good
  "notebook.defaultFormatter": "xaver.clang-format",
  "notebook.formatOnSave.enabled": true,
  "notebook.formatOnCellExecution": true,

  //? 🏃 Emmet Language Support - HTML zen coding everywhere!
  "emmet.includeLanguages": {
    "html": "html",
    "django-html": "html",
    "blade": "html",
    "vue-html": "html",
    "vue": "html",
    "react": "html",
    "javascript": "html"
  },

  // ┌─────────────────────────────────────────────────────────────────┐
  // │              ▶️ CODE RUNNER - THE POLYGLOT'S PARADISE           │
  // │         Execute code in 50+ languages with one keystroke!       │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🏃‍♂️ Code Runner General Settings - Run fast, debug faster!
  "code-runner.clearPreviousOutput": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.runInTerminal": true,

  //? 🌍 The Grand Executor Map - Supporting every language under the sun!
  "code-runner.executorMap": {
    //! 🏗️ Compiled Languages - Build it strong!
    "c": "clear && cd $dir && gcc $fileName -o $fileNameWithoutExt && ./$(basename $fileNameWithoutExt)",
    "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
    "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
    "go": "go run",
    "zig": "zig run",

    //! 📜 Scripting Languages - Script your way to success!
    "python": "clear && python3 -u",
    "javascript": "node",
    "typescript": "ts-node",
    "ruby": "ruby",
    "perl": "perl",
    "perl6": "perl6",
    "php": "php",
    "lua": "lua",

    //! 💻 Shell & System Scripts - Command the command line!
    "shellscript": "bash",
    "powershell": "powershell -ExecutionPolicy ByPass -File",
    "bat": "cmd /c",
    "applescript": "osascript",

    //! 🎓 Functional Languages - For the intellectuals
    "haskell": "runghc",
    "fsharp": "fsi",
    "scala": "scala",
    "clojure": "lein exec",
    "erlang": "escript",
    "lisp": "sbcl --script",
    "scheme": "csi -script",
    "sml": "cd $dir && sml $fileName",

    //! 🆕 Modern Languages - The new kids on the block
    "swift": "swift",
    "kotlin": "kotlin",
    "dart": "dart",
    "julia": "julia",
    "nim": "nim compile --verbosity:0 --hints:off --run",
    "crystal": "crystal",
    "mojo": "mojo run",
    "gleam": "gleam run -m $fileNameWithoutExt",

    //! 🌐 Web Languages - Making the internet pretty
    "coffeescript": "coffee",
    "sass": "sass --style expanded",
    "scss": "scss --style expanded",
    "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",

    //! 🔬 Scientific Languages - For when you need to science!
    "r": "Rscript",
    "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",

    //! 🎪 Exotic Languages - Because why not?
    "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
    "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
    "groovy": "groovy",
    "racket": "racket",
    "ocaml": "ocaml",
    "vbscript": "cscript //Nologo",
    "csharp": "scriptcs",
    "autoit": "autoit3",
    "autohotkey": "autohotkey",
    "ahk": "autohotkey",
    "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
    "kit": "kitc --run",
    "v": "v run",
    "spwn": "spwn build",
    "pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml"
  },

  // ┌─────────────────────────────────────────────────────────────────┐
  // │                🎯 GIT & VERSION CONTROL MASTERY                 │
  // │           Commit, push, and collaborate like a legend           │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🌿 Git Core Configuration - Version control at light speed
  "git.path": "/usr/bin/git",
  "git.autofetch": true,
  "git.enableCommitSigning": true,
  "git.confirmSync": false,
  "git.confirmForcePush": false,
  "git.decorations.enabled": true,
  "git.inputValidation": true,
  "git.inputValidationLength": 50,
  "git.mergeEditor": true,
  "git.useEditorAsCommitInput": true,
  "git.showInlineOpenFileAction": true,
  "git.detectSubmodules": true,
  "git.openRepositoryInParentFolders": "never",
  "git.defaultCloneDirectory": "~/Projects",
  "git.scanRepositories": [],
  "git.ignoredRepositories": ["~/Projects/legacy-repo"],
  "git.branchProtection": ["main", "master"],
  "git.pruneOnFetch": true,
  "git.fetchOnPull": true,
  "git.rebaseWhenSync": true,
  "git.allowNoVerifyCommit": true,
  "git.pullBeforeCheckout": true,

  //? 💪 GitLens - Git superpowers activated!
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.currentLine.enabled": true,
  "gitlens.codeLens.enabled": true,
  "gitlens.hovers.enabled": true,
  "gitlens.statusBar.enabled": true,
  "gitlens.advanced.messages": {
    "suppressCommitHasNoPreviousCommitWarning": true
  },

  //? 🎨 SCM Visual Settings - Clean and minimal
  "scm.diffDecorations": "none",

  // ┌─────────────────────────────────────────────────────────────────┐
  // │         💬 BETTER COMMENTS NEXT - FIXED CONFIGURATION           │
  // └─────────────────────────────────────────────────────────────────┘

  "better-comments.highlightPlainText": true,
  "better-comments.multilineComments": true,
  "better-comments.tags": [
    {
      "tag": "*",
      "color": "#66FF00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "?",
      "color": "#AA00FF",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": true
    },
    {
      "tag": "!",
      "color": "#FF0000",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": ["TODO", "TO-DO", "To-Do"],
      "color": "#FF00FF",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false,
      "multiline": true
    },
    {
      "tag": ["FIXME", "FIX-ME", "FIX"],
      "color": "#DC143C",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false,
      "multiline": true
    },
    {
      "tag": "BUG",
      "color": "#8B00FF",
      "strikethrough": false,
      "underline": true,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "HACK",
      "color": "#00CED1",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": true
    },
    {
      "tag": "NOTE",
      "color": "#1E90FF",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "INFO",
      "color": "#00FFFF",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "IDEA",
      "color": "#000",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "WARNING",
      "color": "#FF0000",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "REVIEW",
      "color": "#FFA500",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    }
  ],

  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },

