      "name": "MrDib's Epic Dictionary",
      "path": "/Users/dibakar/Documents/Documents - DIBAKAR’s MacBook Pro/Code/CustomCode/Dictionaries/mrdib-words.txt",
      "description": "Tech terms, frameworks, Indian languages, and MrDib's favorites 🏆",
      "addWords": true,
