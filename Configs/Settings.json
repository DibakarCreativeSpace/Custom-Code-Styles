  },
  "commentAnchors.tags.displayInRuler": false,
  "commentAnchors.tags.displayInGutter": false,
  "commentAnchors.tags.separators": [" ", ": ", " - "],
  "commentAnchors.workspace.matchFiles": "**/*.txt",
  "commentAnchors.workspace.excludeFiles": "**/.git/**,**/node_modules/**,**/*.md",
  "commentAnchors.tagHighlights.enabled": true,

  // ┌─────────────────────────────────────────────────────────────────┐
  // │               ⚠️ ERROR LENS - BUG DESTROYER 9000                │
  // │                  Making errors impossible to miss!              │
  // └─────────────────────────────────────────────────────────────────┘

  //? ☠️ Error Lens - Because bugs deserve no mercy!
  "errorLens.messageBackgroundMode": "none",
  "errorLens.fontWeight": "800",
  "errorLens.gutterIconsEnabled": true,
  "errorLens.severityText": ["☠️", "☠️", "☠️", "☠️"],
  "errorLens.enabledDiagnosticLevels": ["warning", "info", "error"],

  // ┌─────────────────────────────────────────────────────────────────┐
  // │                  🧘 ZEN MODE - FOCUS MAXIMIZER                  │
  // │              When you need to enter the coding zone             │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🎯 Zen Mode - Distraction-free coding nirvana awaits!
  "zenMode.fullScreen": true,
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": true,
  "zenMode.hideStatusBar": true,
  "zenMode.hideActivityBar": true,
  "zenMode.restore": false,
  "zenMode.silentNotifications": false,

  // ┌─────────────────────────────────────────────────────────────────┐
  // │              🔍 SEARCH & NAVIGATION EXCELLENCE                  │
  // │                   Find anything, anywhere, instantly            │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🔎 Search Configuration - Sherlock Holmes mode activated
  "search.useIgnoreFiles": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": false,

  //? 🚫 Problem Panel - Clean workspace, clear mind
  "problems.decorations.enabled": false,

  // ┌─────────────────────────────────────────────────────────────────┐
  // │            🤖 AI & GITHUB COPILOT CONFIGURATION HQ              │
  // │        Where Human Intelligence Meets Artificial Genius 🧠      │
  // │              "Pair programming with the future!" 🚀             │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🎯 GitHub Copilot - Your AI pair programming partner
  //! May cause addiction to AI-powered coding! Extremely powerful!
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": true,
    "yaml": true,
    "yml": true,
    "json": true,
    "jsonc": true
  },

  "chat.viewSessions.orientation": "stacked",

  //? 💡 Copilot Editor Settings - Fine-tuned for maximum intelligence
  "github.copilot.editor.enableCodeActions": true,

  //? 🎨 Copilot Inline Suggestions - Subtle yet powerful
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.showToolbar": "onHover",

  //? 🔮 AI-Powered Code Assistance - The smart suggestions engine
  //* These settings work with various AI extensions including Copilot
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.suggest.preview": true,
  "editor.suggest.showInlineDetails": true,
  "editor.wordBasedSuggestions": "matchingDocuments",

  // ┌─────────────────────────────────────────────────────────────────┐
  // │                    🔮 MISCELLANEOUS MAGIC                       │
  // │                  The secret sauce ingredients                   │
  // └─────────────────────────────────────────────────────────────────┘

  //? 🌐 Live Preview - Test in real-time like a wizard
  "livePreview.customExternalBrowser": "Default",

  //? 🔒 Security & Privacy - Your code, your rules
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",

  //? 🔄 Profile Settings Sync - Consistency across the multiverse
  "workbench.settings.applyToAllProfiles": [
    "workbench.colorCustomizations",
    "editor.fontFamily",
    "editor.fontSize",
    "editor.lineHeight",
    "terminal.integrated.fontFamily",
    "terminal.integrated.fontSize",
    "files.exclude",
    "search.exclude",
    "emmet.includeLanguages",
    "editor.minimap.enabled",
    "editor.minimap.scale",
    "workbench.editor.showTabs",
    "explorer.autoReveal",
    "git.autofetch",
    "window.zoomLevel"
  ],

  // ┌─────────────────────────────────────────────────────────────────┐
  // │           📚 SPELL CHECK DICTIONARY - THE WORD VAULT            │
  // │        Custom dictionary for all the words VS Code missed       │
  // │                  (It's quite a collection! 🏆)                  │
